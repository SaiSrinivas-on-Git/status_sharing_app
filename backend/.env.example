# ── Firebase Configuration ───────────────────────────────────────
# Path to your Firebase service account JSON key file
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# Your Firebase project ID (e.g., "my-status-app-12345")
FIREBASE_PROJECT_ID=your-firebase-project-id

# ── Owner Configuration ──────────────────────────────────────────
# Firebase UID of the device owner (found in Firebase Console > Authentication)
OWNER_UID=your-owner-firebase-uid

# ── FCM (optional fallback — prefer Firestore-stored token) ──────
# FCM_DEVICE_TOKEN=your-android-device-fcm-token

# ── Google Maps API (optional — for outdoor heuristic) ───────────
# GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated allowed origins
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# ── Server ───────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
DEBUG=true
