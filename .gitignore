# ═══════════════════════════════════════════════════════════════════
# Status Sharing System — .gitignore
# ═══════════════════════════════════════════════════════════════════

# ── Secrets & Credentials (CRITICAL — never commit these) ────────
*.json
!frontend/firebase.json
!package.json
!package-lock.json
!tsconfig.json
firebase-credentials.json
google-services.json
**/firebase-credentials*.json
**/google-services.json
**/*service-account*.json
**/*credentials*.json
*.pem
*.key
*.p12
*.keystore
*.jks

# ── Environment Files ────────────────────────────────────────────
.env
.env.*
!.env.example

# ════════════════════════════════════════════════════════════════
# PYTHON / BACKEND
# ════════════════════════════════════════════════════════════════

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Ruff
.ruff_cache/

# pytype
.pytype/

# ════════════════════════════════════════════════════════════════
# ANDROID
# ════════════════════════════════════════════════════════════════

# Gradle
.gradle/
**/build/
!**/src/**/build/

# Gradle wrapper (keep wrapper jar + properties for reproducible builds)
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

# Local properties (contains SDK path — machine-specific)
local.properties

# Android Studio
*.iml
.idea/
*.hprof

# APK & Bundle outputs
*.apk
*.aab
*.ap_

# Android lint
lint-report.html

# Native crash logs
crashlytics-build.properties

# Google Services (Firebase config — contains API keys)
# Already covered above, but explicit for clarity
android-app/app/google-services.json

# Signing configs
*.keystore
*.jks
signing.properties

# ════════════════════════════════════════════════════════════════
# FRONTEND
# ════════════════════════════════════════════════════════════════

# Node (if npm is used for Firebase tools)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Firebase
.firebase/
.firebaserc

# ════════════════════════════════════════════════════════════════
# IDE / EDITOR
# ════════════════════════════════════════════════════════════════

# VS Code
.vscode/
*.code-workspace

# JetBrains (Android Studio, PyCharm, IntelliJ)
.idea/
*.iml
*.iws
*.ipr
out/

# Vim
*.swp
*.swo
*~

# ════════════════════════════════════════════════════════════════
# OS FILES
# ════════════════════════════════════════════════════════════════

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~

# ════════════════════════════════════════════════════════════════
# DOCKER
# ════════════════════════════════════════════════════════════════

# Docker override files (may contain local overrides)
docker-compose.override.yml

# ════════════════════════════════════════════════════════════════
# MISC
# ════════════════════════════════════════════════════════════════

# Logs
*.log
logs/

# Temporary files
*.tmp
*.temp
*.bak

# Jupyter
.ipynb_checkpoints/
